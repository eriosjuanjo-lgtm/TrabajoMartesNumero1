package com.example;

public class Main {

    static class Product {

        private String id;
        private String name;
        private double price;
        private int stock;

        public Product(String id, String name, double price, int stock) {
            this.id = id;
            this.name = name;
            this.price = price;
            this.stock = stock;
        }

        public String getName() {
            return name;
        }

        public double getPrice() {
            return price;
        }

        public int getStock() {
            return stock;
        }

        public void setPrice(double price) {
            if (price >= 0) {
                this.price = price;
            }
        }

        public void setStock(int stock) {
            if (stock >= 0) {
                this.stock = stock;
            }
        }

        @Override
        public String toString() {
            return "Producto [ID: " + id +
                    ", Nombre: " + name +
                    ", Precio: " + price +
                    ", Stock: " + stock + "]";
        }
    }

    public static void main(String[] args) {

        Product p1 = new Product("P123", "Laptop", 1200.0, 10);
        Product p2 = new Product("P456", "Mouse", 25.5, 50);

        p1.setPrice(1150.0);
        p2.setStock(45);

        System.out.println(p1);
        System.out.println(p2);
    }
}
